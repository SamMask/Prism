{
  "id": "phase18-readiness-core-api",
  "updated_at": "2026-05-27",
  "purpose": "Lock the Python baseline surface for the Phase 18 frontend redesign and the first Go read-only shadow backend.",
  "scope": {
    "included": [
      "Core library reads used by Home, Sidebar filters, Note detail, and external agent read flows",
      "Core note/category/tag writes that the frontend shell must keep compatible with",
      "Prompt Builder option reads/writes as existing settings-backed behavior"
    ],
    "deferred": [
      "File upload and attachment write migration",
      "Import/export rewrite",
      "Server maintenance and Raspberry Pi local-only operations",
      "Prototype-only collections schema, AI, collaboration, timeline, or social features"
    ]
  },
