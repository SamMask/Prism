    "single_delete_handler": "deleteNote",
    "batch_delete_handler": "batchDeleteNotes",
    "cleanup_helper": "cleanupNoteImages and noteAttachmentCleanupPaths",
    "transaction_boundary": "single SQLite transaction per delete request; file cleanup is best-effort and mirrors Python non-fatal cleanup behavior",
